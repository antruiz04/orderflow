# PostgreSQL (una instancia, varias bases de datos — patrón database-per-service en local)
POSTGRES_USER=orderflow
POSTGRES_PASSWORD=orderflow_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

AUTH_DB_NAME=auth_db
CATALOG_DB_NAME=catalog_db
ORDERS_DB_NAME=orders_db
INVENTORY_DB_NAME=inventory_db

# Redpanda (compatible con Kafka, sin Zookeeper)
# - Dentro de Docker: redpanda:9092
# - Desde tu PC (NestJS en local): localhost:19092
KAFKA_BROKER=localhost:19092
KAFKA_BROKER_DOCKER=redpanda:9092

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (compartido entre servicios en dev; en prod usar secret manager)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=1d

# Mailhog (SMTP fake para ver emails en http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025

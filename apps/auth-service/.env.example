# Auth Service — variables locales
# Este servicio corre en tu PC (npm run start:dev), así que Postgres es localhost.

PORT=3001

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=orderflow
POSTGRES_PASSWORD=orderflow_secret
AUTH_DB_NAME=auth_db

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=1d
